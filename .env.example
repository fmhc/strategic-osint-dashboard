# OSINT Dashboard — configuration template. Copy to `.env` and fill in.
#   cp .env.example .env
# (.env is gitignored; never commit real secrets.)

# ── Server ──────────────────────────────────────────────
# HTTP port (3333 by default to avoid the common 3000 clash).
PORT=3333

# ── LLM analysis (any OpenAI-compatible endpoint: OpenAI, vLLM, LiteLLM, LM Studio…) ──
# If LLM_BASE_URL is set, it is used; otherwise the OLLAMA_* fallback below applies.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name
# Optional faster/cheaper tier for high-volume per-entity analysis (else falls back to LLM_MODEL)
LLM_MODEL_FAST=
# For reasoning models, keep chain-of-thought off for fast, clean JSON output
LLM_ENABLE_THINKING=false

# Legacy Ollama fallback (only used when LLM_BASE_URL is empty)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ── Data source credentials (optional) ─────────────────
# AISStream.io — free API key for real-time ship tracking (https://aisstream.io)
AISSTREAM_API_KEY=
# OpenSky Network — Basic auth raises the 400/day unauthenticated quota
# OPENSKY_USER=
# OPENSKY_PASS=

# ── Security ────────────────────────────────────────────
# Comma-separated CORS allowlist. Empty = open to all origins (a startup warning
# is logged). Same-origin / non-browser requests are always allowed.
# ALLOWED_ORIGINS=https://osint.example.com,http://192.168.1.20:3333

# ── Alert thresholds ────────────────────────────────────
PIZZA_INDEX_ALERT_THRESHOLD=500
GPS_JAM_ALERT_THRESHOLD=3
